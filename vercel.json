{
  "framework": "vite",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build",
  "outputDirectory": "artifacts/chemidot/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[...]?_vc_api_path=:path*"
    },
    {
      "source": "/:path((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
